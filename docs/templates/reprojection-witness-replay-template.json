  "decision_rules": {
    "identity_mismatch": {
      "classification": "not_comparable",
      "paper_evidence_eligible": false,
      "no_metric_claim_upgrade": true,
      "claim_gate_result": "identity_mismatch_fail_closed"
    },
    "candidate_pool_mismatch_without_documented_expansion": {
      "classification": "fail_closed_candidate_pool_mismatch",
      "paper_evidence_eligible": false,
      "no_metric_claim_upgrade": true,
      "claim_gate_result": "candidate_pool_mismatch_fail_closed"
    },
    "over_budget_revised_context": {
      "classification": "operational_violation",
      "paper_evidence_eligible": false,
      "no_metric_claim_upgrade": true,
      "claim_gate_result": "over_budget_operational_violation"
    },
    "missing_stale_mismatched_or_underpowered_bridge": {
      "metric_claim_level": "ambiguous_metric",
      "denied_metric_claims": [
        "calibrated_proxy_supported",
        "vinfo_proxy_supported"
      ],
      "paper_evidence_eligible": false,
      "no_metric_claim_upgrade": true
    },
    "fixture_only_before_after_improvement": {
      "claim_ceiling": "operational_audit_only",
      "deployed_runtime_improvement_claim": false,
      "paper_evidence_eligible": false,
      "measurement_validation_claim": false,
      "no_metric_claim_upgrade": true
    }
  },
  "claim_boundary": {
