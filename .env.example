# ===== Base Runtime =====
PYTHONPATH=.
HF_HOME=.cache/huggingface
HF_DATASETS_CACHE=.cache/huggingface/datasets

# ===== DashScope / Bailian =====
# Default locked provider secret for `API_PROFILE=dashscope-qwen-phase1`
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== EVAS OpenAI-compatible API =====
# Optional exploration profile-specific settings
EVAS_API_KEY=
EVAS_API_BASE_URL=https://api.evas.ai/v1
EVAS_FRONTIER_MODEL=openai/gpt-5.4
EVAS_SMALL_MODEL=openai/gpt-5.4-mini
EVAS_CODING_MODEL=openai/gpt-5.3-codex

# ===== Generic API Profile Overrides =====
# Main runtime entrypoint for provider/model switching
API_PROFILE=dashscope-qwen-phase1
# Optional generic overrides. Leave blank to use the selected profile defaults.
API_BASE_URL=
API_KEY=
API_FRONTIER_MODEL=
API_SMALL_MODEL=
API_CODING_MODEL=
# Legacy `PHASE1_*` model env vars remain compatibility-only and are omitted here.

# ===== Phase 0 =====
MUSIQUE_REPO=dgslibisey/MuSiQue
MUSIQUE_SPLIT=validation
PHASE0_SEED=20260418
PHASE0_N_PER_STRATUM=30
PHASE0_POOL_MIN=15
PHASE0_POOL_MAX=25
PHASE0_ARTIFACT_DIR=./artifacts/phase0
PHASE0_MANIFEST_PATH=./artifacts/phase0/sample_manifest_v1.json
PHASE0_HASH_PATH=./artifacts/phase0/content_hashes.json

# ===== Phase 1 Identity =====
PHASE1_EXPERIMENT_ID=musique_gate1_phase1_v1
PHASE1_PROTOCOL_VERSION=phase1.v1
PHASE1_SEED=20260418

# ===== Phase 1 Storage =====
PHASE1_CACHE_DIR=./artifacts/phase1/cache
PHASE1_MEASUREMENT_DIR=./artifacts/phase1/measurements
PHASE1_EXPORT_DIR=./artifacts/phase1/exports
PHASE1_CHECKPOINT_DIR=./artifacts/phase1/checkpoints
